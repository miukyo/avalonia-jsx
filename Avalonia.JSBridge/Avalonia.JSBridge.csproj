<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <EnableDefaultAvaloniaResourceItems>false</EnableDefaultAvaloniaResourceItems>
    <DefaultItemExcludes>$(DefaultItemExcludes);Examples\**;node_modules\**</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <PackageReference Include="Jint" Version="4.10.1" />
    <PackageReference Include="Microsoft.Extensions.FileProviders.Physical" Version="10.0.9" />
  </ItemGroup>

</Project>
